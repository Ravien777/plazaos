# ─── Caddyfile for AgencyOS ──────────────────────────────────────────────────
# Copy to /etc/caddy/Caddyfile on the Hetzner VPS.

yourdomain.com {
    # Reverse proxy to PHP-FPM
    root * /var/www/agencyos/current/public
    php_fastcgi unix//run/php/php8.4-fpm.sock {
        resolve_root_symlink
    }

    # Static asset serving (with hashed filenames, cache forever)
    header /build/* Cache-Control "public, max-age=31536000, immutable"

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }

    # Deny access to hidden files
    @hidden {
        path *.env .git .htaccess artisan.sh composer.json composer.lock package.json tsconfig.json vite.config.js
    }
    respond @hidden 404

    # Standard routes
    encode gzip

    # Logs
    log {
        output file /var/log/caddy/agencyos.log
    }
}
