{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "doctrine/dbal": "^4.4",
        "google/apiclient": "^2.0",
        "inertiajs/inertia-laravel": "^2.0",
        "laravel/fortify": "^1.37",
        "laravel/framework": "^12.0",
        "laravel/reverb": "*",
        "laravel/sanctum": "^4.0",
        "laravel/slack-notification-channel": "^3.8",
        "laravel/tinker": "^2.10.1",
        "league/csv": "^9.28",
        "pusher/pusher-php-server": "*",
        "resend/resend-laravel": "^1.4",
        "stripe/stripe-php": "^20.0",
        "tightenco/ziggy": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.4",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "files": [
            "app/helpers.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "pg:start": "bash bin/pg-start.sh",
        "pg:stop": "bash bin/pg-stop.sh",
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "bash artisan.sh key:generate",
            "bash artisan.sh migrate --force",
            "bash artisan.sh db:seed --force",
            "npm install",
            "npm run build"
        ],
        "seed": "bash artisan.sh db:seed --force",
        "lint": "vendor/bin/pint",
        "lint:test": "vendor/bin/pint --test",
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74,#a7f3d0\" \"bash artisan.sh serve\" \"bash artisan.sh queue:listen --tries=1 --timeout=0\" \"bash artisan.sh pail --timeout=0\" \"bash artisan.sh reverb:start --no-interaction\" \"npm run dev\" --names=server,queue,logs,vite,reverb --kill-others"
        ],
        "test": [
            "bash artisan.sh config:clear --ansi",
            "bash artisan.sh test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
