APP_NAME=PlazaOS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_IP=                         # Bypass maintenance mode for this IP

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                               # production: warning

DB_CONNECTION=pgsql
DB_HOST=                                      # production: 127.0.0.1
DB_PORT=                                      # production: 5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=prefer                             # production: require

SESSION_DRIVER=database                       # production: redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null                           # production: .yourdomain.com
SESSION_SECURE_COOKIE=                        # production: true

SANCTUM_STATEFUL_DOMAINS=                     # production: yourdomain.com

FILESYSTEM_DISK=local                          # production: r2
QUEUE_CONNECTION=database                      # production: redis

CACHE_STORE=database                           # production: redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log                                # production: resend
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_API_KEY=                                # production: (Resend API key)
RESEND_WEBHOOK_SECRET=                         # production: (Resend webhook signing secret)

# Cloudflare R2 (file storage)
AWS_ACCESS_KEY_ID=                             # production: (R2 access key)
AWS_SECRET_ACCESS_KEY=                         # production: (R2 secret key)
AWS_DEFAULT_REGION=auto
AWS_BUCKET=                                    # production: (R2 bucket name)
AWS_URL=                                       # production: (R2 public URL)
AWS_ENDPOINT=                                  # production: (R2 S3 API URL)
AWS_USE_PATH_STYLE_ENDPOINT=true

# Google Calendar integration (meetings)
GOOGLE_CALENDAR_ENABLED=                      # production: true
GOOGLE_CALENDAR_ID=                           # production: (your Gmail address or shared calendar ID)
GOOGLE_CALENDAR_CREDENTIALS_PATH=             # production: storage/app/google-calendar-credentials.json

# Zoom integration (meetings)
ZOOM_ENABLED=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=

# Microsoft Teams integration (meetings)
MICROSOFT_TEAMS_ENABLED=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Slack notifications
SLACK_BOT_USER_OAUTH_TOKEN=                     # production: (Slack Bot User OAuth Token)
SLACK_BOT_USER_DEFAULT_CHANNEL=#general

# OpenAI integration (AI features)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Trello integration
TRELLO_API_KEY=
TRELLO_API_TOKEN=
TRELLO_BOARD_LOW_MEDIUM=
TRELLO_BOARD_HIGH=
TRELLO_BOARD_TODAY=
TRELLO_BOARD_THIS_WEEK=
TRELLO_BOARD_THIS_MONTH=
TRELLO_BOARD_LATER=

# Stripe billing
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_TRIAL_DAYS=14

VITE_APP_NAME="${APP_NAME}"
